@import "../../../../../style/public/comm_box_list.wxss";
@import "../../../style/skin.wxss";

page {
	background-color: var(--projectCompareColor);
}


.main {
	padding: 0rpx 0rpx 100rpx;
}

.hero {
	width: 100%;
	padding: 0 !important;
	position: relative;
	min-height: 430rpx;
	overflow: hidden;
}

.hero image {
	width: 100%;
	min-height: 430rpx;
	display: block;
}

.hero-mask {
	position: absolute;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	background: linear-gradient(180deg, rgba(12, 53, 63, .18), rgba(12, 53, 63, .68));
}

.hero-copy {
	position: absolute;
	left: 40rpx;
	right: 40rpx;
	bottom: 110rpx;
	color: #fff;
}

.hero-copy .eyebrow {
	font-size: 22rpx;
	letter-spacing: 0;
	opacity: .86;
}

.hero-copy .headline {
	font-size: 54rpx;
	font-weight: 800;
	line-height: 1.15;
	margin-top: 10rpx;
}

.hero-copy .subline {
	font-size: 26rpx;
	line-height: 1.5;
	margin-top: 14rpx;
	width: 560rpx;
}

.menu {
	width: 100%;
	margin-top: -72rpx;
	position: relative;
	padding: 0 0rpx;
	overflow: hidden;
	border-top-right-radius: 36rpx;
	border-top-left-radius: 36rpx;
}

.menu .inner {
	position: relative;
	width: 100%;
	display: flex;
	flex-wrap: wrap;
	padding: 28rpx 30rpx 10rpx;
	background-color: var(--projectCompareColor);
	z-index: 999;
	flex-direction: column;
}

.section-title {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 0 6rpx 10rpx;
}

.section-title .title {
	color: #12343B;
	font-size: 32rpx;
	font-weight: 800;
}

.section-title .desc {
	color: #6C7A7D;
	font-size: 24rpx;
	margin-top: 6rpx;
}

.menu .inner .mm {
	display: flex;
	width: 100%;
	flex-wrap: wrap;
}

.menu .inner .mm .item {
	width: 25%;
	display: flex;
	align-items: center;
	justify-content: center;
	height: 180rpx;
}

.menu .inner .mm .item .item-inner {
	width: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;

}

.menu .inner .mm .item .item-inner .img {
	width: 104rpx;
	height: 104rpx;
	display: flex;
	justify-content: center;
	align-items: center;
	border-radius: 28rpx;
	background-color: #fff;
}

.menu .inner .mm .item .item-inner .img image {
	width: 70rpx;
	height: 70rpx;
}

.menu .inner .mm .item .item-inner .title {
	font-size: 26rpx;
	color: #12343B;
	margin-top: 10rpx;
	font-weight: 600;
}

.down {
	width: 100%;
	box-sizing: border-box;
	padding: 10rpx 0rpx;
	z-index: 9999;
	position: relative;
}

.loading {
	color: var(--projectColor) !important;
}

.inspire {
	display: flex;
	padding: 20rpx 30rpx 10rpx;
	gap: 18rpx;
}

.inspire-card {
	flex: 1;
	min-height: 180rpx;
	border-radius: 22rpx;
	padding: 24rpx;
	color: #fff;
	overflow: hidden;
	position: relative;
}

.inspire-card.primary {
	background: linear-gradient(135deg, #0F8B8D, #176B87);
}

.inspire-card.secondary {
	background: linear-gradient(135deg, #F2A541, #E56B3F);
}

.inspire-card .kicker {
	font-size: 20rpx;
	opacity: .82;
}

.inspire-card .name {
	font-size: 30rpx;
	font-weight: 800;
	margin-top: 16rpx;
	line-height: 1.25;
}

.inspire-card .text {
	font-size: 22rpx;
	line-height: 1.4;
	margin-top: 12rpx;
	opacity: .9;
}

.area {
	width: 100%;
	border-radius: 20rpx;
	padding: 10rpx 0 0rpx;
}

.area .hot-line {
	width: 100%;
	display: flex;
	justify-content: space-between;
	padding: 0rpx 30rpx;
	margin-top: 10rpx;
	border-radius: 20rpx;
	align-items: center;
}

.area .hot-line .left {
	font-size: 34rpx;
	font-weight: bold;
	color: #12343B;
	margin-top: 10rpx;
}

.area .hot-line .hint {
	font-size: 22rpx;
	color: #7B8B8E;
	margin-top: 8rpx;
}

.area .hot-line .right {
	font-size: 24rpx;
	color: var(--projectColor);
	background: #E7F7F4;
	border-radius: 999rpx;
	padding: 8rpx 18rpx;
}

.scroll-x {
	width: 100%;
	padding: 0 0rpx 0 30rpx;
}

.scroll-view {
	white-space: nowrap;
	width: 100%;
	flex-direction: row;
}

.scroll-view .product {
	padding: 30rpx 0;
}

.scroll-view .product .scroll-item {
	display: inline-flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	margin-right: 18rpx;
	background: #fff;
	padding: 10rpx;
	border-radius: 20rpx;
	box-shadow: 0 10rpx 26rpx rgba(17, 52, 59, .08);
}


.scroll-view .product .scroll-item image {
	width: 210rpx;
	height: 210rpx;
	margin-bottom: 10rpx;
	border-radius: 16rpx;
}

.scroll-view .product .scroll-item .title {
	font-size: 22rpx;
	color: #333;
	width: 210rpx;
	text-align: left;
}

.scroll-view .activity {
	padding: 30rpx 0;
}

.scroll-view .activity .scroll-item {
	display: inline-flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	position: relative;
	margin-right: 18rpx;
	overflow: hidden;
	border-radius: 20rpx;
	box-shadow: 0 10rpx 26rpx rgba(17, 52, 59, .08);
}

.scroll-view .activity .scroll-item image {
	width: 430rpx;
	height: 220rpx;
	border-radius: 20rpx;
}

.scroll-view .activity .scroll-item .title {
	font-size: 22rpx;
	width: 430rpx;
	text-align: center;
	position: absolute;
	bottom: 0;
	background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, .62));
	color: #fff;
	padding: 42rpx 18rpx 14rpx;
}


.content-list {
	display: flex;
	justify-content: space-between;
	padding: 20rpx 30rpx;
}

.content-left,
.content-right {
	width: 49%;
}

.content-item {
	margin: 10rpx auto 20rpx;
	background: #fff;
	width: 98%;
	border-radius: 18rpx;
	position: relative;
	overflow: hidden;
}

.content-item-img {
	width: 100%;
	overflow: hidden;
	position: relative;
}

.content-item-img>image {
	width: 100%;
	border-top-left-radius: 10rpx;
	border-top-right-radius: 10rpx;
}


.content-item-img .mark {
	position: absolute;
	top: 10rpx;
	right: 10rpx;
	z-index: 9;
	background-color: rgba(199, 135, 72, .7);
	color: #fff;
	font-size: 20rpx;
	padding: 8rpx 10rpx;
	border-radius: 999rpx;
}

.content-item-box {
	font-size: 24rpx;
	color: #333;
	padding: 10rpx 10rpx 20rpx;
	box-sizing: border-box;
	display: flex;
	flex-direction: column;
}

.content-item-box .line1 {
	font-size: 24rpx;
	color: #12343B;
	font-weight: 700;
}

.content-item-box .line2 {
	width: 100%;
	display: flex;
	align-items: center;
	justify-content: flex-start;
	margin-top: 10rpx;
	font-size: 22rpx;
	color: var(--projectColorLight)
}

.content-item-box .line2 .name {
	width: 180rpx;
	color: #999;
}


.content-item-box .line2 .avatar {
	width: 40rpx;
	height: 40rpx;
	border-radius: 50%;
	margin-right: 10rpx;
}

/* ==================== 首页 AI 智能空间样式 ==================== */
.ai-badge {
	margin-left: 16rpx;
	font-size: 20rpx;
	font-weight: bold;
	background: linear-gradient(135deg, #0F8B8D, #00C2FF);
	color: #ffffff;
	padding: 4rpx 14rpx;
	border-radius: 999rpx;
	text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
	animation: ai-badge-glow 2s infinite alternate;
}

.ai-space-card {
	margin: 20rpx 30rpx 30rpx;
	background: #ffffff;
	border-radius: 24rpx;
	padding: 30rpx;
	position: relative;
	overflow: hidden;
	border: 1rpx solid rgba(15, 139, 141, 0.08);
}

.ai-space-card::before {
	content: "";
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 6rpx;
	background: linear-gradient(90deg, #0F8B8D, #00C2FF, #7000FF);
}

.ai-space-header {
	display: flex;
	align-items: center;
	padding-bottom: 24rpx;
	border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.ai-avatar-wrap {
	position: relative;
	width: 90rpx;
	height: 90rpx;
	flex-shrink: 0;
	margin-right: 20rpx;
}

.ai-avatar-glow {
	position: absolute;
	top: -6rpx;
	left: -6rpx;
	width: 102rpx;
	height: 102rpx;
	border-radius: 50%;
	background: linear-gradient(135deg, #0F8B8D, #00C2FF, #7000FF);
	opacity: 0.15;
	animation: ai-glow-spin 4s linear infinite;
}

.ai-avatar-img {
	width: 100%;
	height: 100%;
	border-radius: 50%;
	background-color: #ffffff;
	border: 4rpx solid #ffffff;
	box-shadow: 0 4rpx 12rpx rgba(15, 139, 141, 0.15);
	position: relative;
	z-index: 2;
}

.ai-online-dot {
	position: absolute;
	bottom: 0;
	right: 0;
	width: 20rpx;
	height: 20rpx;
	border-radius: 50%;
	background-color: #39b54a;
	border: 3rpx solid #ffffff;
	z-index: 3;
	animation: ai-dot-pulse 1.5s infinite ease-in-out;
}

.ai-intro {
	flex: 1;
}

.ai-name {
	font-size: 28rpx;
	font-weight: bold;
	color: #12343B;
	margin-bottom: 4rpx;
}

.ai-status {
	font-size: 20rpx;
	color: #88999F;
}

.ai-tools-list {
	display: flex;
	flex-direction: column;
	margin-top: 20rpx;
}

.ai-tool-item {
	display: flex;
	align-items: center;
	padding: 20rpx 16rpx;
	border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
	transition: all 0.2s ease;
	border-radius: 12rpx;
}

.ai-tool-item:last-child {
	border-bottom: none;
}

.ai-tool-item:active {
	background-color: rgba(15, 139, 141, 0.04);
	transform: scale(0.99);
}

.ai-tool-icon {
	font-size: 36rpx;
	margin-right: 20rpx;
	width: 60rpx;
	height: 60rpx;
	border-radius: 50%;
	background-color: rgba(15, 139, 141, 0.08);
	display: flex;
	justify-content: center;
	align-items: center;
	flex-shrink: 0;
}

.ai-tool-info {
	flex: 1;
}

.ai-tool-title {
	font-size: 26rpx;
	font-weight: bold;
	color: #12343B;
	margin-bottom: 2rpx;
}

.ai-tool-desc {
	font-size: 20rpx;
	color: #7B8B8E;
}

.ai-tool-item .icon-right {
	font-size: 20rpx;
	color: #CCCCCC;
}

/* 动效定义 */
@keyframes ai-badge-glow {
	from {
		box-shadow: 0 2rpx 8rpx rgba(15, 139, 141, 0.3);
	}
	to {
		box-shadow: 0 4rpx 16rpx rgba(0, 194, 255, 0.6);
	}
}

@keyframes ai-glow-spin {
	0% {
		transform: rotate(0deg);
	}
	100% {
		transform: rotate(360deg);
	}
}

@keyframes ai-dot-pulse {
	0%, 100% {
		transform: scale(1);
		box-shadow: 0 0 0 0 rgba(57, 181, 74, 0.6);
	}
	50% {
		transform: scale(1.1);
		box-shadow: 0 0 8rpx 6rpx rgba(57, 181, 74, 0);
	}
}

