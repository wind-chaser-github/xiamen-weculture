.photo-list {
	display: flex;
	flex-direction: column;
	gap: 30rpx;
}

.photo-item {
	background-color: #fff;
	border-radius: 20rpx;
	overflow: hidden;
	box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.photo-img {
	width: 100%;
	height: 400rpx;
	display: block;
}

.photo-action {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 20rpx 30rpx;
	background-color: #fcfcfc;
}

.btns {
	display: flex;
	gap: 30rpx;
}

.btn-icon {
	display: flex;
	align-items: center;
	font-size: 28rpx;
	cursor: pointer;
}

.btn-icon text {
	margin-right: 10rpx;
}
