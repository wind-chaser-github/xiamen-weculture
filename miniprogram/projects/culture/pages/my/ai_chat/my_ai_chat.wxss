page {
  height: 100%;
  background-color: #f3f7f6;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  box-sizing: border-box;
}

/* 滚动区域 */
.chat-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.chat-list {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

/* 单条聊天项 */
.chat-item {
  display: flex;
  margin-bottom: 40rpx;
  animation: fadeIn 0.3s ease-out both;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(15rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.chat-user {
  flex-direction: row-reverse;
}

.chat-ai {
  flex-direction: row;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 气泡 */
.bubble-wrap {
  max-width: 70%;
  margin: 0 20rpx;
  display: flex;
  flex-direction: column;
}

.bubble {
  padding: 24rpx 30rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.chat-user .bubble {
  background-color: #0f8b8d;
  color: #ffffff;
  border-top-right-radius: 4rpx;
}

.chat-ai .bubble {
  background-color: #ffffff;
  color: #333333;
  border-top-left-radius: 4rpx;
}

.msg-text {
  white-space: pre-wrap;
}

/* 推荐项目卡片 */
.recommend-box {
  margin-top: 15rpx;
  background-color: rgba(15, 139, 141, 0.06);
  border: 1rpx solid rgba(15, 139, 141, 0.15);
  border-radius: 16rpx;
  padding: 20rpx;
  animation: fadeIn 0.4s ease-out;
}

.recommend-title {
  font-size: 24rpx;
  color: #0f8b8d;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.recommend-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  transition: all 0.2s ease;
}

.recommend-card:last-child {
  margin-bottom: 0;
}

.recommend-card:active {
  transform: scale(0.97);
  background-color: #f7faf9;
}

.rec-left {
  flex: 1;
}

.rec-title {
  font-size: 26rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.rec-hint {
  font-size: 20rpx;
  color: #888888;
}

.rec-right {
  margin-left: 20rpx;
}

/* AI 等待打字点闪烁 */
.thinking-bubble {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 36rpx;
  background-color: #ffffff;
}

.thinking-bubble .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #0f8b8d;
  margin: 0 5rpx;
  opacity: 0.3;
  animation: pulse 1s infinite alternate;
}

.thinking-bubble .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.thinking-bubble .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes pulse {
  to {
    opacity: 1;
    transform: scale(1.2);
  }
}

/* 底部输入栏 */
.input-panel {
  padding: 20rpx 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.input-box {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
}

.input-field {
  flex: 1;
  height: 70rpx;
  font-size: 28rpx;
  padding: 0 15rpx;
}

.send-btn {
  background-color: #cccccc;
  color: #ffffff;
  border-radius: 35rpx;
  font-size: 26rpx;
  padding: 0 35rpx;
  height: 66rpx;
  line-height: 66rpx;
  margin: 0;
  margin-left: 10rpx;
  border: none;
  font-weight: bold;
  transition: all 0.25s ease;
}

.send-btn-active {
  background-color: #0f8b8d !important;
}

.send-btn::after {
  border: none;
}
