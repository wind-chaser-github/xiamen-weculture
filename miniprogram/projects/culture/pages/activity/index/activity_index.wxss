@import "../../../style/skin.wxss";

.main {
	padding: 0rpx !important;
	background: var(--projectCompareColor);
}

.page-head {
	margin: 20rpx 30rpx 20rpx;
	padding: 32rpx;
	border-radius: 26rpx;
	background: linear-gradient(135deg, #0F8B8D, #176B87);
	color: #fff;
}

.page-head .kicker {
	font-size: 20rpx;
	font-weight: 700;
	opacity: .86;
}

.page-head .title {
	font-size: 42rpx;
	font-weight: 800;
	margin-top: 10rpx;
}

.page-head .desc {
	font-size: 24rpx;
	line-height: 1.5;
	margin-top: 12rpx;
	opacity: .9;
}

.list {
	width: 100%;
	padding: 0rpx 20rpx;
	display: flex;
	flex-direction: column;
}

.list .item {
	width: 100%;
	display: flex;
	background-color: #fff;
	padding: 18rpx;
	overflow: hidden;
	position: relative;
	margin-bottom: 24rpx;
	border-radius: 24rpx !important;
}

.list .item .left {
	margin-right: 25rpx;
	position: relative;
	overflow: hidden;
	border-radius: 18rpx;
	width: 210rpx;
	height: 230rpx;
}

.list .item .left .mark {
	position: absolute;
	top: 0;
	left: 0;
	padding: 4rpx 10rpx;
	background-color: rgba(15, 139, 141, .92);
	z-index: 999;
	font-size: 20rpx;
	border-bottom-right-radius: 14rpx;
	color: #fff;
	opacity: .9;
}

.list .item .left image {
	width: inherit;
	height: inherit;
	border-radius: inherit;
}

.list .item .right {
	flex: 1;
	display: flex;
	flex-direction: column;
	justify-content: space-between;
}

.list .item .right .top {
	width: 100%;
	display: flex;
	flex-direction: column;
}

.list .item .right .top .title {
	width: 100%;
	font-size: 30rpx;
	font-weight: bold;
	color: #12343B;
	margin-bottom: 20rpx;
	margin-top: 14rpx;
}

.list .item .right .top .desc {
	width: 100%;
	font-size: 26rpx;
	color: #999;
	margin-bottom: 10rpx;
}

.list .item .right .line {
	width: 100%;
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-top: 24rpx;
}

.list .item .right .line .join {
	font-size: 24rpx !important;
	background-color: var(--greyLight);
	color: #999;
	border-radius: 30rpx;
	line-height: 2;
	padding: 0 30rpx;
}

.list .item .right .line .join.comm {
	background-color: var(--projectColor);
	color: #fff
}

.list .item .right .line .users {
	flex: 1;
	display: flex;
	align-items: center;
}

.list .item .right .line .users .pic-group {
	display: flex;
	padding: 0 10rpx 0 0rpx;
	align-items: center;
}

.list .item .right .line .users .pic-group .pic {
	width: 48rpx !important;
	height: 48rpx !important;
}

.list .item .right .line .users .pic-group .pic {
	margin-left: -20rpx;
	border: 4rpx solid #fff;
	vertical-align: middle;
}

.list .item .right .line .users .pic-group .pic:first-child {
	margin-left: 0rpx;
}

.list .item .right .line .users .num {
	font-size: 24rpx;
	color: #bbb;
}

.tabs .tab-menu.cur {
	color: #000 !important;
	font-size: 30rpx !important;
}

/* ==================== AI 智能行程一键定制面板样式 ==================== */
.ai-generator-panel {
	margin: 0 30rpx 20rpx;
	padding: 24rpx 30rpx;
	border-radius: 26rpx;
	background: #ffffff;
	border: 1rpx solid rgba(15, 139, 141, 0.08);
	position: relative;
	overflow: hidden;
}

.ai-generator-panel::before {
	content: "";
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 6rpx;
	background: linear-gradient(90deg, #0F8B8D, #00C2FF);
}

.ai-gen-header {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 20rpx;
}

.ai-gen-title {
	display: flex;
	align-items: center;
	font-size: 26rpx;
	font-weight: bold;
	color: #12343B;
}

.ai-gen-icon {
	color: #0f8b8d;
	margin-right: 10rpx;
	font-size: 32rpx;
	animation: ai-icon-pulse 1.8s infinite ease-in-out;
}

.ai-gen-badge {
	font-size: 18rpx;
	font-weight: bold;
	background: linear-gradient(135deg, #0F8B8D, #00C2FF);
	color: #ffffff;
	padding: 2rpx 10rpx;
	border-radius: 6rpx;
}

.ai-gen-tags {
	display: flex;
	gap: 16rpx;
	margin-bottom: 20rpx;
}

.ai-gen-tag {
	font-size: 22rpx;
	color: #7B8B8E;
	background-color: #F4FAF8;
	padding: 8rpx 20rpx;
	border-radius: 30rpx;
	border: 1rpx solid rgba(15, 139, 141, 0.1);
	transition: all 0.2s ease;
}

.ai-gen-tag-active {
	background-color: #E7F7F4 !important;
	color: #0f8b8d !important;
	font-weight: bold;
	border-color: #0f8b8d !important;
}

.ai-gen-form {
	display: flex;
	gap: 16rpx;
	align-items: center;
}

.ai-gen-input {
	flex: 1;
	height: 64rpx;
	background-color: #f6f7fb;
	border-radius: 12rpx;
	padding: 0 20rpx;
	font-size: 24rpx;
	color: #12343B;
}

.ai-gen-btn {
	height: 64rpx;
	line-height: 64rpx;
	background: linear-gradient(135deg, #0F8B8D, #00C2FF);
	color: #ffffff;
	font-size: 24rpx;
	font-weight: bold;
	border-radius: 12rpx;
	padding: 0 24rpx;
	margin: 0;
	border: none;
}

.ai-gen-btn::after {
	border: none;
}

.ai-gen-btn:active {
	transform: scale(0.97);
	opacity: 0.9;
}
